# ============================================================
# qevie / passpay — environment variables template
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --------------- Network RPCs ---------------
QIE_TESTNET_RPC=https://rpc1testnet.qie.digital/
QIE_MAINNET_RPC=https://rpc1mainnet.qie.digital/

# --------------- Deployer keys ---------------
# Never commit real private keys. Use funded QIE accounts.
TESTNET_PRIVATE_KEY=
MAINNET_PRIVATE_KEY=
DEPLOY_PRIVATE_KEY=

# --------------- Contract addresses (testnet 1983) ---------------
# Populated after Phase 1-3 deployment.
ENTRYPOINT_ADDRESS=0xa07d2Ff33400fbE2c741385cb959D5BCbA041493
ACCOUNT_FACTORY_ADDRESS=0x6ed8b09371e133dab2AC87Da81615D3152092E3A
PAYMASTER_ADDRESS=
BATCH_PAYMENTS_ADDRESS=
PAYMENT_REQUEST_ADDRESS=
SUBSCRIPTION_MANAGER_ADDRESS=
USERNAME_REGISTRY_ADDRESS=
RECEIPT_REGISTRY_ADDRESS=

# --------------- Token addresses (verified mainnet + testnet) ---------------
QUSDC_ADDRESS=0x3F43DA82eC9A4f5285F10FaF1F26EcA7319E5DA5
WQIE_ADDRESS=0x0087904D95BEe9E5F24dc8852804b547981A9139
DEX_PAIR_ADDRESS=0x73a3cCF7da7e473ed2e9994aE764f0E30f4e4DFe

# --------------- Paymaster service ---------------
# Key used by paymaster-service to sign Mode B allowlist tokens.
# Must match the trustedSigner address passed to QeviePaymaster constructor.
PAYMASTER_SIGNER_PRIVATE_KEY=
TRUSTED_SIGNER_ADDRESS=

# Optional: comma-separated addresses for manual allowlist (testing)
MANUAL_ALLOWLIST=

# --------------- QIE Domain Resolver (optional) ---------------
# Forward resolver (name.qie -> address) used by the paymaster-service preview
# path. Leave empty to keep `.qie` forward resolution cleanly unavailable (never
# faked). Reverse verification uses the verified QIE Domains registry in config.
QIE_DOMAIN_RESOLVER_ADDRESS=

# Secret used to encrypt server-custodied Autopilot session keys at rest
# (AES-256-GCM). REQUIRED for /session-key provisioning — without it the
# endpoint fails closed. Use a long random value, e.g. `openssl rand -hex 32`.
SESSION_KEY_ENC_SECRET=
# Optional: path to the encrypted session-key store (default ./data/session-keys.json)
SESSION_KEY_STORE_PATH=

# --------------- Autopilot executor ---------------
# Runs due Autopilot payment intents with the policy's custodied session key.
# Set to "false" to disable the executor loop (provisioning still works).
AUTOPILOT_EXECUTOR_ENABLED=true
# Poll interval for the executor loop, in milliseconds.
AUTOPILOT_POLL_INTERVAL_MS=60000
# Optional: path to the Autopilot intent store (default ./data/autopilot-intents.json)
AUTOPILOT_INTENT_STORE_PATH=

# --------------- Bundler (Voltaire, unsafe mode) ---------------
BUNDLER_SECRET=change_me_in_production
BUNDLER_PORT=4337

# --------------- App (Vite) ---------------
VITE_USE_TESTNET=true
VITE_TESTNET_RPC=https://rpc1testnet.qie.digital/
VITE_MAINNET_RPC=https://rpc1mainnet.qie.digital/
VITE_BUNDLER_URL=http://localhost:4337
VITE_PAYMASTER_SERVICE_URL=http://localhost:3001
VITE_APP_BASE_URL=https://app.qevie.io
VITE_SKIP_CONTRACT_CHECK=true
VITE_RECEIPT_REGISTRY_ADDRESS=
# Set only after AgentPolicyManager is deployed, explorer-verified, and recorded in VERIFICATION.md.
VITE_AGENT_POLICY_MANAGER_ADDRESS=
# Enable only after SDK policy creation and session UserOp submission are wired and tested.
VITE_AUTOPILOT_EXECUTION_ENABLED=false

# QIE Domain Resolver (optional, chain-aware). REGISTRY = reverse verification
# (address -> name.qie); RESOLVER = forward (name.qie -> address). With no
# resolver set, `.qie` forward resolution is cleanly unavailable (never faked).
# The mainnet registry defaults to the verified proxy when left empty.
# Do NOT set a resolver address until it is explorer-verified in VERIFICATION.md.
VITE_QIE_DOMAIN_RESOLVER_MAINNET=
VITE_QIE_DOMAIN_RESOLVER_TESTNET=
VITE_QIE_DOMAIN_REGISTRY_MAINNET=
VITE_QIE_DOMAIN_REGISTRY_TESTNET=

# --------------- Paymaster service ---------------
USE_TESTNET=true
PORT=3001
KEEPER_POLL_INTERVAL_MS=60000
